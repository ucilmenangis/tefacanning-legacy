flowchart TD
    START([Mulai]) --> LANDING[Tampilkan Landing Page]
    LANDING --> LOGIN_ADMIN[/Form Login Admin/]
    LOGIN_ADMIN --> AUTH_ADMIN{Autentikasi Valid?}
